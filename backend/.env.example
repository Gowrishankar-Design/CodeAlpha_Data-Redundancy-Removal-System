# Optional. Leave unset to use a local SQLite file (backend/drrs.db) — zero setup.
# Set this to a Postgres connection string for storage that survives every
# redeploy, not just restarts. Free options: Neon (neon.tech), Supabase, or
# Render's own Postgres add-on.
#
# DATABASE_URL=postgresql://user:password@host:5432/dbname
